<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Activity window theme. The in-app UI colors come from Compose
         (ui/Theme.kt); this just gives a dark window + no action bar. -->
    <style name="Theme.EntroTunnel" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
    </style>
</resources>
